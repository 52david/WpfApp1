<Window x:Class="WpfApp1.KrestikiNoliki"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="KrestikiNoliki" Height="450" Width="800">
    <Grid Background="#FFA4EAF7">
        <Grid Name="GameGrid" Background="LightGray" Margin="169,22,173,47">
            <Button  Grid.Row="0" Grid.Column="0" Click="Button_Click" Content="Button" HorizontalAlignment="Left" Margin="11,9,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Height="106" Width="138">
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="0.505"/>
                        <RotateTransform Angle="-0.607"/>
                        <TranslateTransform X="0.006" Y="0.608"/>
                    </TransformGroup>
                </Button.RenderTransform>
            </Button>
            <Button Grid.Row="0" Grid.Column="0" Click="Button_Click" Content="Button" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Height="105" Width="142"/>
            <Button Grid.Row="0" Grid.Column="0" Click="Button_Click" Content="Button" HorizontalAlignment="Left" Margin="308,10,0,0" VerticalAlignment="Top" Height="105" Width="140"/>
            <Button Grid.Row="0" Grid.Column="0" Click="Button_Click" Content="Button" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" Height="104" Width="142"/>
            <Button Grid.Row="0" Grid.Column="0" Click="Button_Click" Content="Button" HorizontalAlignment="Center" VerticalAlignment="Center" Height="104" Width="142"/>
        </Grid>
        <Grid x:Name="GameGrid_Copy" Background="#FF5B5B5B" Margin="169,22,173,47">
            <Button Content="Button" HorizontalAlignment="Left" Margin="11,9,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5" Height="106" Width="138" Click="Button_Click">
                <Button.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform AngleY="0.505"/>
                        <RotateTransform Angle="-0.607"/>
                        <TranslateTransform X="0.006" Y="0.608"/>
                    </TransformGroup>
                </Button.RenderTransform>
            </Button>
            <Button Grid.Row="0" Grid.Column="0" Click="Button_Click" Content="Button" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top" Height="105" Width="142"/>
            <Button Grid.Row="0" Grid.Column="1" Click="Button_Click" Content="Button" HorizontalAlignment="Left" Margin="308,10,0,0" VerticalAlignment="Top" Height="105" Width="140"/>
            <Button Grid.Row="1" Grid.Column="2" Click="Button_Click" Content="Button" HorizontalAlignment="Left" Margin="10,0,0,0" VerticalAlignment="Center" Height="104" Width="142"/>
            <Button Grid.Row="1" Grid.Column="1" Click="Button_Click" Content="Button" HorizontalAlignment="Center" VerticalAlignment="Center" Height="104" Width="142"/>
            <Button Grid.Row="1" Grid.Column="2" Click="Button_Click" Content="Button" HorizontalAlignment="Left" VerticalAlignment="Center" Height="104" Width="142" Margin="306,0,0,0"/>
            <Button Grid.Row="2" Grid.Column="0" Click="Button_Click" Content="Button" HorizontalAlignment="Left" VerticalAlignment="Top" Height="104" Width="142" Margin="10,251,0,0"/>
            <Button Grid.Row="2" Grid.Column="1" Click="Button_Click" Content="Button" HorizontalAlignment="Center" VerticalAlignment="Top" Height="104" Width="142" Margin="0,251,0,0"/>
            <Button Grid.Row="2" Grid.Column="2" Click="Button_Click" Content="Button" HorizontalAlignment="Left" VerticalAlignment="Top" Height="104" Width="142" Margin="306,251,0,0"/>
        </Grid>

    </Grid>
</Window>
